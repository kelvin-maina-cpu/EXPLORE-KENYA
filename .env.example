NODE_ENV=development
PORT=5000

# MongoDB Atlas (get free cluster at mongodb.com/atlas)
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/explorekenya?retryWrites=true&w=majority

# JWT Secret (keep secure, generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production

# Google Maps API Key (for frontend maps)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# M-Pesa Credentials (sandbox)
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_passkey
MPESA_ENDPOINT=https://sandbox.safaricom.co.ke
